{
  "name": "ai-fication-kit",
  "version": "0.1.0",
  "description": "Make any legacy repository AI-native, with a human in the loop",
  "type": "module",
  "main": "install.mjs",
  "bin": {
    "ai-fication-kit": "./install.mjs"
  },
  "files": [
    "install.mjs",
    "install.py",
    "lib/",
    "templates/",
    "CHANGELOG.md",
    "NOTICE",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "node -e \"require('fs').rmSync('lib/__pycache__',{recursive:true,force:true})\"",
    "shazam": "node install.mjs shazam",
    "orient": "node install.mjs orient",
    "setup": "node install.mjs install",
    "remove": "node install.mjs uninstall",
    "test": "node test/run-tests.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kunalsuri/ai-fication-kit.git"
  },
  "keywords": [
    "ai",
    "agent",
    "claude-code",
    "onboarding",
    "scaffolding",
    "legacy-codebase",
    "ai-native"
  ],
  "author": "Kunal Suri",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/kunalsuri/ai-fication-kit/issues"
  },
  "homepage": "https://github.com/kunalsuri/ai-fication-kit#readme",
  "engines": {
    "node": ">=18"
  }
}
